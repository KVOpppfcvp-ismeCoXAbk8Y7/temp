#!/usr/bin/bash

set -eu

WDIR="$(pwd)"
ROOT="$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")"

cleanup() {
  local status=$?

  pushd "$WDIR"
  exit $status
}

main() {
  trap cleanup EXIT

  . "${ROOT}/lib/vite.bash"

  pushd "$CTX"

  cp -f package.template.json package.json

  docker run --rm -v "$CTX":/app -w /app "node:22-alpine" sh -c "
    rm -f package-lock.json
    rm -rf node_modules

    npm install ${PACKAGES[*]}
    npm install -D ${PACKAGES_DEV[*]}
    npm install --package-lock-only

    chown -R 1001:1001 node_modules
    chown 1001:1001 package-lock.json
  "
}

main
